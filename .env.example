# Upload- und Datenserver (optional). Wenn gesetzt: Fotos/Dokumente und Aufträge werden auf dem Server gespeichert – für alle Nutzer sichtbar.
# Beispiel lokal: http://localhost:3010
# Beispiel Produktion: https://deine-domain.de
VITE_API_URL=http://localhost:3010

# QGIS Server (Backend) – wird von `server/index.js` genutzt:
# Beispiel: https://gis.example.com/ows
QGIS_WMS_BASE_URL=

# WMS Layer (Frontend) – wird in der /qgis Seite vorbelegt:
VITE_QGIS_WMS_LAYERS=
